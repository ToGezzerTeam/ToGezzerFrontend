# Voice Chat Configuration
# Copy this to .env.local and update the values

# Backend WebSocket URL
# For development:
VITE_WS_URL=http://localhost:3000
VITE_DEFAULT_API=http://localhost:8081
# For production:
# VITE_VOICE_CHAT_WS_URL=wss://api.example.com

# Mediasoup configuration (informational, server-side)
VITE_MEDIASOUP_WORKER_LOG_LEVEL=warn

# Voice Chat Feature Flags
VITE_ENABLE_VOICE_CHAT=true
VITE_ENABLE_VIDEO_CHAT=false

# Audio Configuration
VITE_AUDIO_ECHO_CANCELLATION=true
VITE_AUDIO_NOISE_SUPPRESSION=true
VITE_AUDIO_AUTO_GAIN_CONTROL=true

# Volume sensitivity (0.0 - 1.0)
VITE_VOLUME_METER_SENSITIVITY=0.5

